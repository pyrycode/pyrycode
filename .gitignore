# Build artifacts
/pyry
/dist/
*.test
*.out

# Flight-recorder session recordings (PYRY_RECORD_DIR, #552). Belt-and-
# suspenders: the production default lives outside the repo, but if an operator
# points PYRY_RECORD_DIR inside the tree while debugging, recordings (which can
# contain full session content) never get committed.
*.cast

# Go
/vendor/

# Editors
.vscode/
.idea/
*.swp

# OS
.DS_Store

# Local env
.env
.env.local

# MCP config (machine-specific paths)
.mcp.json

# Agents (separate repo: pyrycode/agents)
agents/

# CodeGraph index (used by dispatcher worktree symlink + interactive
# Claude Code sessions for symbol-level code intel — local cache only).
# No trailing slash: matches both directories AND symlinks. The trailing
# slash variant `.codegraph/` matches directories only, which let the
# dispatcher's worktree symlink at `<wt>/.codegraph` slip past gitignore
# and get auto-committed (commit 30f3d53, "architect: auto-commit
# uncommitted changes for #237"). Result: a tracked symlink-to-self
# that `git checkout -- .` kept restoring on every cleanup.
.codegraph
.dispatcher.lock
