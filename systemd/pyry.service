[Unit]
Description=Pyrycode daemon — Claude Code process supervisor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Adjust to your workspace path if different.
WorkingDirectory=%h/pyry-workspace
# Make sure `claude` is on PATH; override as needed.
Environment="PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin"
# -pyry-resume is the default; pass any claude args after pyry's own flags.
ExecStart=%h/.local/bin/pyry
Restart=always
RestartSec=2
# Give claude time to flush state on shutdown.
TimeoutStopSec=10
# Capture stdout/stderr to the journal.
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
